{
  "subject": "Verify Your Email - AffTrack",
  "template": "\n<!DOCTYPE html>\n<html>\n<head>\n    <meta charset=\"utf-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Verify Email</title>\n    <style>\n        body { background-color: #F8FAFC; color: #334155; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; margin: 0; padding: 0; }\n        .container { max-width: 600px; margin: 40px auto; background: #ffffff; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1); }\n        .header { background-color: #0B3C5D; padding: 32px; text-align: center; }\n        .header h1 { color: #ffffff; margin: 0; font-size: 26px; font-weight: 700; }\n        .content { padding: 40px 32px; text-align: center; }\n        h2 { color: #0B3C5D; font-size: 22px; font-weight: 600; margin-top: 0; }\n        p { line-height: 1.6; color: #475569; margin-bottom: 24px; }\n        .button { background-color: #00B3A4; color: #ffffff; padding: 14px 32px; border-radius: 8px; text-decoration: none; display: inline-block; font-weight: 600; font-size: 16px; margin: 16px 0; transition: background-color 0.2s; }\n        .button:hover { background-color: #009e91; }\n        .footer { background-color: #F8FAFC; padding: 24px; text-align: center; font-size: 13px; color: #94a3b8; border-top: 1px solid #e2e8f0; }\n        .disclaimer { font-size: 12px; color: #94a3b8; margin-top: 24px; }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <div class=\"header\">\n            <h1>AffTrack</h1>\n        </div>\n        <div class=\"content\">\n            <h2>Verify Your Email Address</h2>\n            <p>Hello {{name}},</p>\n            <p>Please verify your email address to secure your account and access all features of AffTrack.</p>\n            \n            <a href=\"{{verificationUrl}}\" class=\"button\">Verify Email</a>\n            \n            <p class=\"disclaimer\">This link will expire in {{expiryTime}} hours. If you did not sign up for AffTrack, you can safely ignore this email.</p>\n        </div>\n        <div class=\"footer\">\n            <p>&copy; 2026 AffTrack. All rights reserved.</p>\n        </div>\n    </div>\n</body>\n</html>"
}