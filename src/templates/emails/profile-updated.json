{
  "subject": "Profile Updated Successfully",
  "template": "\n<!DOCTYPE html>\n<html>\n<head>\n    <meta charset=\"utf-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Profile Updated</title>\n    <style>\n        body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; }\n        .container { max-width: 600px; margin: 0 auto; padding: 20px; }\n        .header { background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%); color: white; padding: 30px; text-align: center; border-radius: 10px 10px 0 0; }\n        .content { background: #f9f9f9; padding: 30px; }\n        .changes-box { background: white; padding: 20px; border-radius: 8px; margin: 20px 0; }\n        .button { display: inline-block; background: #3b82f6; color: white; padding: 12px 30px; text-decoration: none; border-radius: 5px; margin: 20px 0; }\n        .footer { text-align: center; margin-top: 30px; color: #666; font-size: 14px; border-radius: 0 0 10px 10px; background: #f9f9f9; padding: 20px; }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <div class=\"header\">\n            <h1>✓ Profile Updated</h1>\n        </div>\n        <div class=\"content\">\n            <h2>Hello {{customerName}}!</h2>\n            <p>Your profile has been successfully updated.</p>\n            \n            <div class=\"changes-box\">\n                <p><strong>Updated Date:</strong> {{updatedDate}}</p>\n                \n                {{#if changedFields}}\n                <h3>Changes Made:</h3>\n                <ul>\n                {{#each changedFields}}\n                    <li>{{this}}</li>\n                {{/each}}\n                </ul>\n                {{/if}}\n            </div>\n            \n            <p>If you didn't make these changes, please contact our support team immediately.</p>\n            \n            <a href=\"{{profileUrl}}\" class=\"button\">View Profile</a>\n        </div>\n        <div class=\"footer\">\n            <p>Questions? Contact us at support@example.com</p>\n            <p>© 2024 Zlivoo. All rights reserved.</p>\n        </div>\n    </div>\n</body>\n</html>"
}
