{
  "subject": "Welcome Back! Your Account is Reactivated",
  "template": "\n<!DOCTYPE html>\n<html>\n<head>\n    <meta charset=\"utf-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Account Reactivated</title>\n    <style>\n        body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; }\n        .container { max-width: 600px; margin: 0 auto; padding: 20px; }\n        .header { background: linear-gradient(135deg, #10b981 0%, #059669 100%); color: white; padding: 30px; text-align: center; border-radius: 10px 10px 0 0; }\n        .content { background: #f9f9f9; padding: 30px; }\n        .button { display: inline-block; background: #10b981; color: white; padding: 12px 30px; text-decoration: none; border-radius: 5px; margin: 20px 0; }\n        .footer { text-align: center; margin-top: 30px; color: #666; font-size: 14px; border-radius: 0 0 10px 10px; background: #f9f9f9; padding: 20px; }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <div class=\"header\">\n            <h1>🎉 Welcome Back!</h1>\n        </div>\n        <div class=\"content\">\n            <h2>Hello {{customerName}}!</h2>\n            <p>Great to have you back! Your account has been successfully reactivated.</p>\n            \n            <p><strong>Reactivated Date:</strong> {{reactivatedDate}}</p>\n            \n            <p>You now have full access to all features:</p>\n            <ul>\n                <li>✓ Browse and shop products</li>\n                <li>✓ View your order history</li>\n                <li>✓ Manage your wishlist</li>\n                <li>✓ Access your saved addresses</li>\n                <li>✓ Receive exclusive offers</li>\n            </ul>\n            \n            <a href=\"{{loginUrl}}\" class=\"button\">Start Shopping</a>\n            \n            <p>We're glad to have you back in our community!</p>\n        </div>\n        <div class=\"footer\">\n            <p>Questions? Contact us at support@example.com</p>\n            <p>© 2024 Zlivoo. All rights reserved.</p>\n        </div>\n    </div>\n</body>\n</html>"
}
