{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": "./",
    "paths": {
      "@constants/*": ["src/constants/*"],
      "@config/*": ["src/config/*"],
      "@core/*": ["src/core/*"],
      "@middlewares/*": ["src/middlewares/*"],
      "@modules/*": ["src/modules/*"],
      "@utils/*": ["src/utils/*"],
      "@jobs/*": ["src/jobs/*"],
      "@services/*": ["src/services/*"],
      "@routes/*": ["src/routes/*"],
      "@generated/*": ["generated/*"]
    },
    "typeRoots": ["./node_modules/@types", "./src/types"],
    "types": ["node", "express"]
  },
  "include": ["src/**/*.ts",],
  "exclude": [
    "node_modules",
    "tests",
    "**/*.test.ts",
    "**/*.spec.ts",
    "src/modules/notification/**/*.ts",
    "src/services/cache-warming.service.ts",
    "src/services/feature-flag.service.ts",
    "src/services/socket.service.ts"
  ]
}
